COMPOSE_PROJECT_NAME=wp-dev

# PHP version — selects the wordpress:php<version>-fpm base image tag
# Valid values: 7.4 (legacy) | 8.2 | 8.3 | 8.4
PHP_VERSION=8.3

# WordPress core version fetched during the image build (wp core download).
# "latest", or a pinned MAJOR.MINOR[.PATCH] captured from a source site (e.g. 6.5.2).
WP_VERSION=latest
WP_DEBUG=true

# Immutable creation profile recorded in .spawnwp/blueprint.json
SPAWNWP_BLUEPRINT=development
SPAWNWP_BLUEPRINT_VERSION=1.0.0

# Database
DB_NAME=wordpress
DB_USER=wpuser
DB_PASS=<generated>
DB_ROOT_PASS=<generated>
DB_TABLE_PREFIX=wp_

# WordPress admin (created on first bootstrap only)
WP_ADMIN_USER=admin
WP_ADMIN_EMAIL=admin@example.com
WP_ADMIN_PASS=<generated>

# Site URL
WP_HOME=https://dev.example.com
WP_SITEURL=https://dev.example.com

# Container web port (loopback only)
WEB_PORT=8080

# Adminer DB GUI port (loopback only)
ADMINER_PORT=9001

# Redis (enabled only with --profile redis)
REDIS_PASSWORD=<generated>
